#!/usr/bin/env bash
# penny — Penny service management CLI
#
# Usage: penny <command> [args]
#
# Service:
#   start              Start Penny via launchd
#   stop               Stop Penny and keep it stopped (KeepAlive disabled)
#   quit               Quit Penny gracefully (launchd restarts if KeepAlive is on)
#   status             Show running/stopped status
#
# Data:
#   refresh            Trigger a live data refresh
#   tasks              List ready tasks
#   agents             List running agents
#
# Actions:
#   run <task-id>      Spawn a Claude agent for a task
#   stop-agent <id>    Stop a running agent
#   dismiss <id>       Dismiss a completed task notification
#   clear-completed    Clear all completed task notifications
#
# UI / Config:
#   open               Open the dashboard in your browser
#   logs [-f]          Show recent logs (-f to follow/stream)
#   prefs              Open config.yaml in your default editor
#
set -euo pipefail

PLIST_LABEL="com.gpxl.penny"
PLIST_DEST="$HOME/Library/LaunchAgents/$PLIST_LABEL.plist"
UID_VAL="$(id -u)"
TARGET="gui/$UID_VAL/$PLIST_LABEL"

# Resolve PENNY_HOME: honour env var, else read from plist, else default
if [[ -z "${PENNY_HOME:-}" ]]; then
  PENNY_HOME=$(python3 - "$PLIST_DEST" <<'PYEOF'
import plistlib, os, sys
plist = sys.argv[1]
try:
    with open(plist, "rb") as f:
        pl = plistlib.load(f)
    print(pl.get("EnvironmentVariables", {}).get("PENNY_HOME", os.path.expanduser("~/.penny")))
except Exception:
    print(os.path.expanduser("~/.penny"))
PYEOF
  )
fi

LOG_FILE="$PENNY_HOME/logs/launchd.log"
CONFIG_FILE="$PENNY_HOME/config.yaml"
PORT_FILE="$PENNY_HOME/.dashboard_port"
DEFAULT_PORT=7432

# ── helpers ───────────────────────────────────────────────────────────────────

_is_running() {
  launchctl list "$PLIST_LABEL" &>/dev/null
}

_require_running() {
  if ! _is_running; then
    echo "Penny is not running. Start it with: penny start"
    exit 1
  fi
}

_get_port() {
  if [[ -f "$PORT_FILE" ]]; then cat "$PORT_FILE"; else echo "$DEFAULT_PORT"; fi
}

_api_get() {
  local path="$1"
  local port; port=$(_get_port)
  python3 - "$port" "$path" <<'PYEOF'
import sys, urllib.request, json
port, path = sys.argv[1], sys.argv[2]
try:
    with urllib.request.urlopen(f"http://127.0.0.1:{port}{path}", timeout=5) as r:
        print(r.read().decode())
except Exception as e:
    print(json.dumps({"error": str(e)}))
PYEOF
}

_api_post() {
  local path="$1"
  local body="${2:-{}}"
  local port; port=$(_get_port)
  python3 - "$port" "$path" "$body" <<'PYEOF'
import sys, urllib.request, json
port, path, body = sys.argv[1], sys.argv[2], sys.argv[3]
data = body.encode()
req = urllib.request.Request(
    f"http://127.0.0.1:{port}{path}", data=data,
    headers={"Content-Type": "application/json"}
)
try:
    with urllib.request.urlopen(req, timeout=5) as r:
        print(r.read().decode())
except Exception as e:
    print(json.dumps({"error": str(e)}))
PYEOF
}

_check_api_response() {
  local resp="$1"
  local ok
  ok=$(python3 -c "import sys,json; d=json.loads(sys.argv[1]); print('ok' if d.get('ok') else d.get('error','unknown error'))" "$resp" 2>/dev/null || echo "parse error")
  if [[ "$ok" != "ok" ]]; then
    echo "Error: $ok" >&2
    exit 1
  fi
}

# ── commands ──────────────────────────────────────────────────────────────────

case "${1:-}" in

  start)
    if _is_running; then
      echo "Penny is already running."
      exit 0
    fi
    if [[ ! -f "$PLIST_DEST" ]]; then
      echo "Plist not found at $PLIST_DEST — run install.sh first."
      exit 1
    fi
    launchctl bootstrap "gui/$UID_VAL" "$PLIST_DEST"
    echo "Penny started."
    ;;

  stop)
    if ! _is_running; then
      echo "Penny is not running."
      exit 0
    fi
    # Patch KeepAlive=false before bootout so launchd does not restart.
    # _sync_launchd_service() restores the correct value from config.yaml on next start.
    python3 - "$PLIST_DEST" <<'PYEOF'
import plistlib, sys
path = sys.argv[1]
with open(path, "rb") as f:
    pl = plistlib.load(f)
pl["KeepAlive"] = False
with open(path, "wb") as f:
    plistlib.dump(pl, f)
PYEOF
    launchctl bootout "$TARGET" 2>/dev/null || true
    echo "Penny stopped. Run 'penny start' to restart."
    ;;

  quit)
    _require_running
    resp=$(_api_post /api/quit)
    _check_api_response "$resp"
    echo "Penny quit. launchd will restart it automatically (KeepAlive is on)."
    ;;

  status)
    if _is_running; then
      echo "Penny is running."
    else
      echo "Penny is not running."
    fi
    ;;

  refresh)
    _require_running
    resp=$(_api_post /api/refresh)
    _check_api_response "$resp"
    echo "Refresh triggered."
    ;;

  tasks)
    _require_running
    result=$(_api_get /api/state)
    python3 - "$result" <<'PYEOF'
import sys, json
data = json.loads(sys.argv[1])
if "error" in data:
    print(f"Error: {data['error']}")
    sys.exit(1)
tasks = data.get("ready_tasks", [])
if not tasks:
    print("No ready tasks.")
else:
    print(f"{'ID':<14} {'Pri':<4} {'Project':<20} Title")
    print("-" * 72)
    for t in tasks:
        print(f"{t['task_id']:<14} {t['priority']:<4} {t.get('project_name','')[:20]:<20} {t['title'][:34]}")
PYEOF
    ;;

  agents)
    _require_running
    result=$(_api_get /api/state)
    python3 - "$result" <<'PYEOF'
import sys, json
data = json.loads(sys.argv[1])
if "error" in data:
    print(f"Error: {data['error']}")
    sys.exit(1)
agents = data.get("state", {}).get("agents_running", [])
if not agents:
    print("No agents running.")
else:
    print(f"{'ID':<14} {'Project':<20} Title")
    print("-" * 60)
    for a in agents:
        print(f"{a.get('task_id','?'):<14} {a.get('project_name','')[:20]:<20} {a.get('title','')[:26]}")
PYEOF
    ;;

  run)
    task_id="${2:-}"
    if [[ -z "$task_id" ]]; then
      echo "Usage: penny run <task-id>"
      exit 1
    fi
    _require_running
    body=$(printf '{"task_id":"%s"}' "$task_id")
    resp=$(_api_post /api/run "$body")
    _check_api_response "$resp"
    echo "Agent started for $task_id."
    ;;

  stop-agent)
    task_id="${2:-}"
    if [[ -z "$task_id" ]]; then
      echo "Usage: penny stop-agent <task-id>"
      exit 1
    fi
    _require_running
    body=$(printf '{"task_id":"%s"}' "$task_id")
    resp=$(_api_post /api/stop-agent "$body")
    _check_api_response "$resp"
    echo "Stopped agent $task_id."
    ;;

  dismiss)
    task_id="${2:-}"
    if [[ -z "$task_id" ]]; then
      echo "Usage: penny dismiss <task-id>"
      exit 1
    fi
    _require_running
    body=$(printf '{"task_id":"%s"}' "$task_id")
    resp=$(_api_post /api/dismiss "$body")
    _check_api_response "$resp"
    echo "Dismissed $task_id."
    ;;

  clear-completed)
    _require_running
    resp=$(_api_post /api/clear-completed)
    _check_api_response "$resp"
    echo "Cleared completed tasks."
    ;;

  open)
    port=$(_get_port)
    open "http://127.0.0.1:$port/"
    ;;

  logs)
    if [[ "${2:-}" == "-f" || "${2:-}" == "--follow" ]]; then
      tail -f "$LOG_FILE"
    else
      tail -n 80 "$LOG_FILE"
    fi
    ;;

  prefs)
    open "$CONFIG_FILE"
    ;;

  *)
    sed -n '2,20p' "$0" | sed 's/^# \?//'
    exit 1
    ;;

esac
