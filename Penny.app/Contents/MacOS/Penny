#!/bin/bash
# Penny launcher — cd to project root and exec the Python module.
# This script lives inside Penny.app/Contents/MacOS/ so we go up 3 levels.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
cd "$PROJECT_ROOT"
exec -a "Penny" python3 -m penny.app
