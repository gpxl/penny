#!/bin/bash
# Nae Nae launcher — cd to project root and exec the Python module.
# This script lives inside NaeNae.app/Contents/MacOS/ so we go up 3 levels.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
cd "$PROJECT_ROOT"
exec -a "Nae Nae" python3 -m naenae.app
