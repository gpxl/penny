# ────────────────────────────────────────────────────────────────────────────
# Penny — First-run setup checklist
# ────────────────────────────────────────────────────────────────────────────
# Before Penny can run agents, complete each step:
#
#   [ ] 1. Install the claude CLI:  npm install -g @anthropic-ai/claude-code
#   [ ] 2. Authenticate:            claude auth login
#   [ ] 3. Edit this file:          Replace PLACEHOLDER_PROJECT_PATH below
#   [ ] 4. Verify setup:            bash install.sh --check
#
# Optional (unlocks task management):
#   [ ] Install beads CLI:   brew install beads  (or: npm install -g @beads/bd)
#   [ ] Init beads:          cd ~/your-repo && bd init
#   → Penny auto-detects beads and activates the task management plugin.
#
# ────────────────────────────────────────────────────────────────────────────

projects:
  - path: PLACEHOLDER_PROJECT_PATH   # Replace with: ~/Documents/GitHub/your-repo
    priority: 1
  # - path: ~/Documents/GitHub/another-project
  #   priority: 2

trigger:
  min_capacity_percent: 30    # Spawn agents if ≥30% capacity predicted unused
  max_days_remaining: 2       # …and ≤2 days remain in the week

work:
  max_agents_per_run: 2
  task_priority_levels: [P1, P2, P3]
  agent_permissions: "off"   # off | scoped | full  (default: off — monitoring only)
  # allowed_tools:           # only used when agent_permissions: scoped
  #   - Read
  #   - Edit
  #   - Write
  #   - Glob
  #   - Grep
  #   - "Bash(git:*)"
  #   - "Bash(bd:*)"

notifications:
  spawn: true
  completion: true
  weekly_summary: true

stats_cache_path: ~/.claude/stats-cache.json

service:
  keep_alive: true       # launchd restarts Penny automatically if it exits
  launch_at_login: true  # Penny starts when you log in

plugins:
  beads: auto   # auto = activate when 'bd' CLI is found in PATH (default)
                # true = always activate | false = disable
