# ────────────────────────────────────────────────────────────────────────────
# Penny — Configuration
# ────────────────────────────────────────────────────────────────────────────
# Prerequisites:
#   [ ] 1. Install the claude CLI:  npm install -g @anthropic-ai/claude-code
#   [ ] 2. Authenticate:            claude auth login
#
# Penny monitors your Claude Code token usage out of the box.
# No further configuration is required for monitoring.
# ────────────────────────────────────────────────────────────────────────────

stats_cache_path: ~/.claude/stats-cache.json

service:
  keep_alive: true       # launchd restarts Penny automatically if it exits
  launch_at_login: true  # Penny starts when you log in

notifications:
  weekly_summary: true

# ── Plugin automation (inactive in current release) ──────────────────────────
